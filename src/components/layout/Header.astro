---
/**
 * Header Component (P0)
 * 
 * App Header style navigation bar - solid white, subtle border.
 * - Sticky on scroll
 * - NO backdrop blur (per architectural guidance)
 * - Mobile hamburger menu (React island)
 * 
 * @see docs/bw-prd-01-rebrand.xml - component-inventory > Layout
 */

import MobileMenu from './MobileMenu';

interface Props {
  /** Currently active page path for nav highlighting */
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Navigation links - shared between desktop and mobile
const navLinks = [
  { label: 'Product', href: '/product' },
  { label: 'Solutions', href: '/solutions' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
];

const ctaLink = { label: 'Get Started', href: '/contact' };
---

<header
  class="sticky top-0 z-sticky w-full bg-[var(--color-surface)] border-b border-[var(--color-divider)]"
  data-header
>
  <nav class="container flex h-16 items-center justify-between md:h-16">
    <!-- Logo -->
    <a 
      href="/" 
      class="flex items-center gap-2 text-[var(--color-text-primary)] hover:opacity-80 transition-opacity duration-fast"
      aria-label="Beings - Home"
    >
      <svg 
        class="h-8 w-auto"
        viewBox="0 0 140 32" 
        fill="none"
        aria-hidden="true"
      >
        <!-- Icon mark -->
        <circle cx="16" cy="16" r="14" fill="currentColor" opacity="0.1"/>
        <path 
          d="M10 8h8a6 6 0 0 1 0 12h-8V8zm0 12h8a6 6 0 0 1 0 12h-8V20z" 
          fill="currentColor" 
          opacity="0.9"
        />
        <!-- Wordmark -->
        <text 
          x="40" 
          y="22" 
          font-family="'Roboto Flex', Helvetica, Arial, sans-serif" 
          font-size="18" 
          font-weight="600" 
          fill="currentColor"
        >
          beings
        </text>
      </svg>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex md:items-center md:gap-6">
      <ul class="flex items-center gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-sm transition-colors duration-fast',
                currentPath === link.href 
                  ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/[0.08]' 
                  : 'text-[var(--color-text-primary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/[0.08]'
              ]}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA Button - 8px radius, no uppercase, semibold -->
      <a
        href={ctaLink.href}
        class="btn-primary"
      >
        {ctaLink.label}
      </a>
    </div>

    <!-- Mobile Menu (React Island) -->
    <div class="md:hidden">
      <MobileMenu 
        client:media="(max-width: 767px)"
        links={navLinks}
        ctaLabel={ctaLink.label}
        ctaHref={ctaLink.href}
      />
    </div>
  </nav>
</header>

<style>
  /* Primary Button - M3 compliant */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.5;
    color: white;
    background-color: var(--color-primary);
    border-radius: var(--radius-sm); /* 8px */
    text-transform: none; /* NOT uppercase */
    transition: 
      background-color var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .btn-primary:hover {
    background-color: var(--color-primary-light);
    box-shadow: var(--elevation-1);
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
