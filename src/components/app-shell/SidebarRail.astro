<style>
  .sidebar-rail {
    width: var(--shell-rail-width);
    min-width: var(--shell-rail-width);
    height: 100dvh;           /* Fixed viewport height (matches product) */
    position: sticky;         /* Stays in place when content scrolls */
    top: 0;
    display: flex;
    flex-direction: column;
    background: var(--shell-canvas);
    border-right: var(--shell-rail-border);
    overflow: hidden;
  }

  /* Main content area - matches NavigationRailHeader Box */
  .rail-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    /* KEY: Product padding - py: 0.75rem, pl: 1rem */
    padding: var(--shell-rail-padding-y) 0 var(--shell-rail-padding-y) var(--shell-rail-padding-x);
    /* KEY: Left-aligned, not centered */
    align-items: flex-start;
  }

  /* Header row with hamburger */
  .rail-header {
    flex-shrink: 0;
    margin-bottom: 0.5rem; /* mb: 1 in MUI = 8px */
  }

  /* Hamburger uses text-primary (darker than other icons) */
  .rail-header .rail-button {
    color: var(--shell-text-primary);
  }

  /* Navigation area - scrollable */
  .rail-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* Footer area - fixed at bottom with logo FAB */
  .rail-footer {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 0.5rem; /* Extra bottom padding for FAB */
    border-top: 1px solid var(--shell-divider);
  }

  /* Logo button - inherits rail-button styles, uses currentColor */
  .logo-button {
    text-decoration: none;
  }

  /* Rail button - 48x48 touch target */
  .rail-button {
    width: var(--shell-icon-button-size);
    height: var(--shell-icon-button-size);
    min-width: var(--shell-icon-button-size);
    min-height: var(--shell-icon-button-size);
    padding: var(--shell-icon-button-padding);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    border-radius: var(--shell-radius-sm);
    color: var(--shell-text-secondary);
    cursor: pointer;
    transition: 
      background-color var(--shell-duration-fast) var(--shell-ease-standard),
      color var(--shell-duration-fast) var(--shell-ease-standard);
  }

  .rail-button svg {
    width: var(--shell-icon-size);
    height: var(--shell-icon-size);
  }

  /* Disabled state (matches product's opacity and action.disabled color) */
  .rail-button:disabled {
    opacity: 0.6;
    cursor: default;
    color: rgba(0, 0, 0, 0.26);  /* MUI action.disabled */
  }

  /* Hover states - match product behavior */
  
  /* Hamburger: 4% black overlay (MUI IconButton default) */
  .rail-header .rail-button:hover:not(:disabled) {
    background-color: rgba(0, 0, 0, 0.04);
  }
  
  /* Inactive workspace icons: 15% primary on hover */
  .rail-nav .rail-button:not([data-active="true"]):hover:not(:disabled) {
    background-color: rgba(91, 111, 204, 0.15);
  }
  
  /* Active icons (workspace + logo): 10% → 15% primary on hover */
  .rail-button[data-active="true"]:hover:not(:disabled) {
    background-color: rgba(91, 111, 204, 0.15);
  }

  /* Active state - blue tint background AND blue icon */
  .rail-button[data-active="true"] {
    background-color: rgba(91, 111, 204, 0.10);
    color: var(--shell-primary);  /* Blue icon when active */
  }

  /* Focus state */
  .rail-button:focus-visible {
    outline: 2px solid var(--shell-primary);
    outline-offset: 2px;
  }

  /* Pressed state */
  .rail-button:active:not(:disabled) {
    background-color: rgba(0, 0, 0, 0.12);
  }
</style>
