---
/**
 * SidebarRail Component
 * 
 * Marketing adaptation of product sidebar rail.
 * Width: 80px (5rem) from RAIL_WIDTH
 * 
 * PHASE 1 STATE: Only hamburger icon visible.
 * Hidden elements (preserved for Phase 2):
 * - Workspace navigation icons (personal, org)
 * - Beings logo FAB at bottom
 * 
 * @see /Users/davejohnstone/_dev/beings/src/layouts/Sidebar.tsx
 */

interface Props {
  /** Optional class for customization */
  class?: string;
}

const { class: className } = Astro.props;
---

<aside class:list={["sidebar-rail", className]}>
  <!-- Navigation content area (matches NavigationRailHeader) -->
  <div class="rail-content">
    <!-- Header row: Hamburger button (first element, no logo) -->
    <div class="rail-header">
      <button class="rail-button" aria-label="Toggle sidebar">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
        </svg>
      </button>
    </div>

    <!-- HIDDEN FOR PHASE 1 - Workspace/Navigation icons
    <nav class="rail-nav" aria-label="Main navigation">
      <button class="rail-button" aria-label="Personal" data-active="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
      </button>
      <button class="rail-button" aria-label="Org Workspaces" disabled>
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
        </svg>
      </button>
    </nav>
    -->
  </div>

