---
/**
 * BentoCards — Direct port from live studio.workspace.google.com
 * 
 * Three-card flex row: 1 featured (520×208) + 2 compact (168×208).
 * All cards use 48px border radius.
 * Featured has blue shadow, compacts have purple bg.
 * 
 * Values verified via DevTools on live site 2026-02-06.
 */

interface BentoCard {
  label?: string;
  title: string;
  ctaLabel?: string;
  ctaHref?: string;
  variant: 'featured' | 'compact';
  icon?: string;
}

interface Props {
  cards?: BentoCard[];
}

const { cards = [
  {
    variant: 'featured',
    label: 'Unlimited uploads',
    title: 'Upload video, audio or text and let Beings transcribe and AI-index it for free',
    ctaLabel: 'Try free',
    ctaHref: '/signup',
  },
  {
    variant: 'compact',
    title: 'Analyze quickly',
  },
  {
    variant: 'compact',
    title: 'Build your intelligence',
  },
] } = Astro.props;

const featured = cards.find(c => c.variant === 'featured');
const compacts = cards.filter(c => c.variant === 'compact');
---

<!-- Bento container: live site flex, gap 16px -->
<div class="bento-wrapper">
  <div class="bento-row">
    <!-- Featured card: 520×208, white bg, blue shadow -->
    {featured && (
      <a href={featured.ctaHref || '/signup'} class="bento-card featured">
        <div class="bento-card-content">
          {featured.label && <span class="bento-label">{featured.label}</span>}
          <h3 class="bento-title">{featured.title}</h3>
          <div class="bento-footer">
            <span class="bento-cta">{featured.ctaLabel || 'Turn on'}</span>
          </div>
        </div>
      </a>
    )}

    <!-- Compact cards: 168×208, purple bg, no shadow -->
    {compacts.map((card) => (
      <a href="/signup" class="bento-card compact">
        <div class="bento-card-content">
          <h3 class="bento-title-compact">{card.title}</h3>
          <div class="bento-icon-circle">
            <svg viewBox="0 0 24 24" fill="currentColor" class="bento-icon">
              <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  /* Wrapper — BW-02: Removed max-width/padding (now on .content-body) */
  .bento-wrapper {
    /* Spacing handled by Phase 2 vertical rhythm tokens */
  }

  /* Bento row — live site: flex, gap 16px (--layout-component-gap) */
  .bento-row {
    display: flex;
    gap: var(--layout-component-gap); /* 1rem / 16px */
  }

  /* Shared card styles — BW-02: Grayscale skeleton, dimensions from live site */
  .bento-card {
    height: 13rem; /* 208px */
    border-radius: 3rem; /* 48px — M3 extraExtraLarge */
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    overflow: hidden;
    background: #f5f5f5; /* Grayscale placeholder */
  }

  /* Featured card — live site: 520px width */
  .bento-card.featured {
    width: 32.5rem; /* 520px */
    background: #f0f0f0; /* Slightly different gray to distinguish */
  }

  /* Compact cards — live site: 168px width */
  .bento-card.compact {
    width: 10.5rem; /* 168px */
    background: #e8e8e8; /* Grayscale — Phase 4 restores #F7EDFF */
  }

  /* Card content layout */
  .bento-card-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 2rem 1.5rem;
  }

  /* Featured card label — BW-02: Grayscale */
  .bento-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary); /* Grayscale — Phase 4 restores #7438d2 */
    margin-bottom: 0.25rem;
  }

  /* Featured card title — BW-02: Grayscale */
  .bento-title {
    font-size: 1.375rem; /* 22px */
    font-weight: 400;
    color: var(--color-text-primary); /* Grayscale */
    line-height: 1.27;
    flex: 1;
  }

  /* Featured card footer with CTA */
  .bento-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* CTA button — BW-02: Grayscale skeleton */
  .bento-cta {
    display: inline-flex;
    align-items: center;
    height: 2.5rem;
    padding: 0 1.5rem;
    border-radius: 1.25rem; /* 20px */
    background: #505050; /* Grayscale WCAG AA compliant (5.86:1 on white) — Phase 4 restores #7438d2 */
    color: white;
    font-size: 0.8333rem;
    font-weight: 400;
  }

  /* Compact card title — BW-02: Grayscale */
  .bento-title-compact {
    font-size: 1.375rem; /* 22px */
    font-weight: 400;
    color: var(--color-text-primary); /* Grayscale — Phase 4 restores #280255 */
    line-height: 1.27;
    margin: 0;
  }

  /* Compact card icon circle — BW-02: Grayscale */
  .bento-icon-circle {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: auto;
    align-self: center;
  }

  .bento-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: #505050; /* Grayscale WCAG AA — Phase 4 restores #7438d2 */
  }

  /* Responsive — M3 compact breakpoint: stack vertically, full width */
  @media (max-width: 599px) {
    .bento-row {
      flex-direction: column;
    }
    .bento-card.featured,
    .bento-card.compact {
      width: 100%;
    }
    .bento-card.compact {
      height: 7.5rem; /* 120px — shorter on mobile */
    }
  }
</style>
