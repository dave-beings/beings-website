---
/**
 * SecurityArchitecture — 3-column sovereign trust block
 * 
 * BW-02 Enterprise Skeleton
 * Replaces generic "Trust Pillars" with CISO-facing security narrative.
 * Grayscale only — no icons yet, placeholder boxes.
 * 
 * Height: ~400px
 */

const pillars = [
  {
    title: 'Local-First Processing',
    description: 'Audio and video are transcribed on-device. Raw media never leaves your infrastructure. No cloud round-trip, no exposure.',
    badge: 'Zero Upload',
  },
  {
    title: 'UK Data Residency',
    description: 'When you choose to sync, data stays in UK jurisdiction. Cloudflare Western Europe infrastructure. Contractual guarantee.',
    badge: 'UK Sovereign',
  },
  {
    title: 'Zero-Training Promise',
    description: 'Your data is never used to train models. No retention, no reuse, no fine-tuning. Contractually binding, not just policy.',
    badge: 'IP Protected',
  },
];
---

<div class="security-arch">
  <div class="security-header">
    <h2 class="security-title">Security architecture built for regulated industries</h2>
    <p class="security-subtitle">Designed to pass vendor assessments from Day 1.</p>
  </div>

  <div class="pillar-grid">
    {pillars.map((pillar) => (
      <div class="pillar">
        <div class="pillar-icon-placeholder" aria-hidden="true"></div>
        <span class="pillar-badge">{pillar.badge}</span>
        <h3 class="pillar-title">{pillar.title}</h3>
        <p class="pillar-desc">{pillar.description}</p>
      </div>
    ))}
  </div>

  {/* Security architecture diagram placeholder */}
  <div class="arch-diagram" aria-label="Data flow: Local Processing → Encrypted Vault → Your Cloud (Optional)">
    <div class="diagram-placeholder">
      <span class="diagram-label">Security Architecture Diagram</span>
      <span class="diagram-flow">Local Device → Encrypted Vault → UK Cloud (Optional)</span>
    </div>
  </div>
</div>

<style>
  .security-arch {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .security-header {
    text-align: center;
  }

  .security-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .security-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--layout-component-gap);
  }

  .pillar {
    background: #fafafa;
    border-radius: 1rem; /* 16px — M3 large */
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pillar-icon-placeholder {
    width: 3rem;
    height: 3rem;
    background: #e0e0e0;
    border-radius: 0.75rem;
  }

  .pillar-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pillar-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .pillar-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .arch-diagram {
    background: #f5f5f5;
    border-radius: 0.75rem;
    padding: 2rem;
    text-align: center;
  }

  .diagram-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .diagram-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diagram-flow {
    font-size: 1rem;
    color: var(--color-text-secondary);
    font-family: monospace;
  }

  @media (max-width: 599px) {
    .pillar-grid {
      grid-template-columns: 1fr;
    }
    .security-title {
      font-size: 1.375rem;
    }
  }
</style>
