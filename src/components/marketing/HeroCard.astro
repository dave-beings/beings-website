---
/**
 * HeroCard — Hero section with headline, accent word, subhead, and stadium input.
 * 
 * Layout: rounded card with top-anchored content (WS Studio pattern).
 * Content sits in the upper 2/3; bottom 1/3 is breathing room with
 * a gradient fade to white.
 */

import StadiumInput from './StadiumInput';

interface Props {
  headline?: string;
  accentWord?: string;
  subhead?: string;
  placeholder?: string;
}

const {
  headline = 'Research transcription you can',
  accentWord = 'trust',
  subhead = 'Fast, accurate transcripts from any recording or meeting — free',
  placeholder = 'Click to start speaking...',
} = Astro.props;
---

<div class="hero-card">
  <h1 id="hero-heading" class="hero-headline">
    {headline}{' '}<span class="hero-accent">{accentWord}</span>
  </h1>
  <p class="hero-subhead">{subhead}</p>
  <StadiumInput client:visible placeholder={placeholder} />
</div>

<style>
  .hero-card {
    border-radius: 1.75rem; /* 28px — M3 extraLarge */
    padding: 3rem 3rem 2rem;
    /* No min-height — card shrink-wraps to content + padding */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start; /* top-anchored — content in upper 2/3 */
    gap: 1rem; /* 16px — headline to subhead */
    text-align: center;
    position: relative;
    /* Beings brand gradient — soft blue/purple tints, WS geometry.
     * Fade-to-white in the bottom 20% creates breathing room. */
    background:
      linear-gradient(rgba(255,255,255,0) 50%, rgb(255,255,255) 80%),
      radial-gradient(120% 255% at 5% 100%,
        rgb(255,255,255) 0px,
        rgb(227,235,255) 10%,
        rgb(227,235,255) 20%,
        rgb(255,255,255) 50%,
        rgb(247,237,255) 80%,
        rgb(215,206,248) 95%);
  }

  .hero-headline {
    font-size: 2.8125rem; /* 45px */
    font-weight: 500;
    color: var(--color-text-primary);
    letter-spacing: normal;
    line-height: 1.155;
    margin: 0;
  }

  /* Gradient accent word — Beings brand blue→lavender→purple */
  .hero-accent {
    background: linear-gradient(
      90deg,
      var(--color-primary, #5B6FCC),
      var(--color-primary-light, #8D9EE8),
      var(--color-secondary, #7E57C2)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subhead {
    font-size: 1.5rem; /* 24px */
    color: var(--color-text-primary);
    font-weight: 400;
    margin: 0;
    line-height: 2rem; /* 32px — M3 headline-small line-height */
  }

  @media (max-width: 599px) {
    .hero-card {
      border-radius: 1.5rem; /* 24px */
      padding: 2rem 1.5rem;
    }
    .hero-headline {
      font-size: 2rem; /* 32px */
    }
  }
</style>
