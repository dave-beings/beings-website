---
/**
 * ComparisonTable — Public AI vs Beings Sovereign AI
 * 
 * BW-02 Enterprise Skeleton
 * Answers: "Why not just use Copilot/Teams AI?"
 * Grayscale only.
 * 
 * Height: ~350px
 */

const rows = [
  { feature: 'Data Processing', publicAi: 'Cloud servers (US/Global)', beings: 'On-device, local-first' },
  { feature: 'Data Training', publicAi: 'May train on your data', beings: 'Zero training — contractual guarantee' },
  { feature: 'Data Residency', publicAi: 'Global (US, EU, Asia)', beings: 'UK only — Western Europe infrastructure' },
  { feature: 'Client IP Protection', publicAi: 'Shared model context window', beings: 'Isolated processing, no cross-contamination' },
  { feature: 'Regulatory Compliance', publicAi: 'Varies by provider', beings: 'ISO 27001, Cyber Essentials+, NHS DSPT' },
  { feature: 'Offline Capability', publicAi: 'Requires internet', beings: 'Fully functional offline' },
];
---

<div class="comparison">
  <div class="comparison-header">
    <h2 class="comparison-title">Public AI vs. Sovereign AI</h2>
    <p class="comparison-subtitle">The tools your team already uses weren't built for confidential research.</p>
  </div>

  <div class="comparison-table-wrapper">
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="col-feature">Feature</th>
          <th class="col-public">Public AI</th>
          <th class="col-beings">Beings</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td class="cell-feature">{row.feature}</td>
            <td class="cell-public">{row.publicAi}</td>
            <td class="cell-beings">{row.beings}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .comparison {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .comparison-header {
    text-align: center;
  }

  .comparison-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }

  .comparison-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .comparison-table-wrapper {
    overflow-x: auto;
    border-radius: 0.75rem;
    border: 1px solid var(--color-divider);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .comparison-table th {
    text-align: left;
    padding: 1rem 1.25rem;
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    background: #fafafa;
    border-bottom: 1px solid var(--color-divider);
  }

  .comparison-table td {
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--color-divider);
    vertical-align: top;
  }

  .comparison-table tr:last-child td {
    border-bottom: none;
  }

  .cell-feature {
    font-weight: 500;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .cell-public {
    color: var(--color-text-secondary);
  }

  .cell-beings {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .col-feature { width: 25%; }
  .col-public { width: 37.5%; }
  .col-beings { width: 37.5%; }

  @media (max-width: 599px) {
    .comparison-table {
      font-size: 0.8125rem;
    }
    .comparison-table th,
    .comparison-table td {
      padding: 0.75rem;
    }
  }
</style>
