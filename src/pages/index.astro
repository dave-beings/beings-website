---
/**
 * Homepage
 * 
 * Shell-first marketing page using the AppShell layout.
 * Content lives inside the floating white panel.
 * 
 * @see docs/bw-prd-01-rebrand.xml
 */

import AppShell from '../components/app-shell/AppShell.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Beings | AI-Powered Qualitative Research</title>
    <meta name="description" content="Beings helps researchers analyze qualitative data faster with AI-powered coding, theming, and insights." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <AppShell>
      <!-- Marketing content goes here (Phase 2) -->
      <div class="empty-state">
        <p>Beings</p>
        <small>Marketing content coming in Phase 2</small>
      </div>
    </AppShell>
  </body>
</html>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: calc(100vh - 1rem);
    color: var(--shell-text-secondary);
    text-align: center;
    gap: 0.5rem;
  }

  .empty-state p {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--shell-text-primary);
  }

  .empty-state small {
    font-size: 0.875rem;
  }
</style>
