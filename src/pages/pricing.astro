---
/**
 * Pricing Page
 * 
 * SaaS pricing table with tiers.
 * Critical for B2B buyer qualification per Gemini Guardian.
 */
import Layout from '../components/layout/Layout.astro';
import Button from '../components/ui/Button.astro';

const tiers = [
  {
    name: 'Free',
    price: '£0',
    period: 'forever',
    description: 'For individual researchers exploring the platform.',
    features: [
      'Unlimited transcription',
      'AI-powered indexing',
      '3 projects',
      '5GB storage',
      'UK data residency',
    ],
    cta: 'Get Started',
    href: '/signup',
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '£29',
    period: '/month',
    description: 'For serious researchers and small teams.',
    features: [
      'Everything in Free',
      'Unlimited projects',
      '50GB storage',
      'Advanced AI analysis',
      'Team collaboration (3 seats)',
      'Priority support',
    ],
    cta: 'Start Free Trial',
    href: '/signup?plan=pro',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For organizations requiring compliance and scale.',
    features: [
      'Everything in Professional',
      'Unlimited seats',
      'Unlimited storage',
      'SSO / SAML',
      'Custom data retention',
      'Dedicated support',
      'SLA guarantee',
    ],
    cta: 'Contact Sales',
    href: '/contact',
    highlighted: false,
  },
];

const faqs = [
  {
    question: 'Is my data really stored in the UK?',
    answer: 'Yes. All data is processed and stored exclusively in UK data centers (Azure UK South). We never transfer your data outside UK jurisdiction.',
  },
  {
    question: 'Can I try before I buy?',
    answer: 'Absolutely. The Free tier has no time limit, and Professional includes a 14-day free trial. No credit card required.',
  },
  {
    question: 'What happens to my data if I cancel?',
    answer: 'You own your data. On cancellation, you can export everything. After 30 days, data is permanently deleted from our servers.',
  },
  {
    question: 'Do you offer academic discounts?',
    answer: 'Yes. Academic institutions and non-profits receive 50% off Professional plans. Contact us for verification.',
  },
];
---

<Layout
  title="Pricing"
  description="Simple, transparent pricing for qualitative research. Start free, scale as you grow."
>
  <!-- Hero -->
  <section class="pricing-hero">
    <div class="container">
      <h1 class="hero-title">Simple, transparent pricing</h1>
      <p class="hero-subtitle">
        Start free. No credit card required. Upgrade when you're ready.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pricing-section">
    <div class="container">
      <div class="pricing-grid">
        {tiers.map((tier) => (
          <div class={`pricing-card ${tier.highlighted ? 'highlighted' : ''}`}>
            {tier.highlighted && <div class="popular-badge">Most Popular</div>}
            
            <div class="tier-header">
              <h2 class="tier-name">{tier.name}</h2>
              <div class="tier-price">
                <span class="price">{tier.price}</span>
                <span class="period">{tier.period}</span>
              </div>
              <p class="tier-description">{tier.description}</p>
            </div>

            <ul class="feature-list">
              {tier.features.map((feature) => (
                <li class="feature-item">
                  <svg class="check-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <div class="tier-cta">
              <Button 
                href={tier.href} 
                variant={tier.highlighted ? 'primary' : 'outline'} 
                fullWidth
              >
                {tier.cta}
              </Button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-section">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
          </svg>
          <span>UK Data Sovereignty</span>
        </div>
        <div class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
          </svg>
          <span>End-to-End Encrypted</span>
        </div>
        <div class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span>GDPR Compliant</span>
        </div>
        <div class="trust-item">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-5 14H4v-4h11v4zm0-5H4V9h11v4zm5 5h-4V9h4v9z"/>
          </svg>
          <span>Works Offline</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      
      <div class="faq-grid">
        {faqs.map((faq) => (
          <div class="faq-item">
            <h3 class="faq-question">{faq.question}</h3>
            <p class="faq-answer">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2 class="cta-title">Ready to own your research?</h2>
      <p class="cta-subtitle">Start with the Free plan. No credit card required.</p>
      <div class="cta-actions">
        <Button href="/signup" variant="primary" size="lg">Get Started Free</Button>
        <Button href="/demo" variant="outline" size="lg">Book a Demo</Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .pricing-hero {
    padding: 4rem 0 3rem;
    text-align: center;
    background: 
      linear-gradient(rgba(255,255,255,0) 50%, rgb(255,255,255) 100%),
      radial-gradient(120% 255% at 50% 0%,
        rgb(255,255,255) 0%,
        var(--hero-tint-primary-hero) 30%,
        rgb(255,255,255) 70%);
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--mkt-color-text-dark);
    margin: 0 0 1rem;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--mkt-color-text-muted);
    margin: 0;
  }

  /* Pricing Section */
  .pricing-section {
    padding: 3rem 0 4rem;
  }

  .pricing-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }

  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-marketing-card-medium);
    padding: 2rem;
    position: relative;
    transition: transform var(--duration-short3) var(--ease-standard),
                box-shadow var(--duration-short3) var(--ease-standard);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .pricing-card.highlighted {
    border-color: var(--mkt-color-primary);
    box-shadow: var(--shadow-primary-purple);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--mkt-color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .tier-header {
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-divider);
    margin-bottom: 1.5rem;
  }

  .tier-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--mkt-color-text-dark);
    margin: 0 0 0.75rem;
  }

  .tier-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--mkt-color-text-dark);
  }

  .period {
    font-size: 1rem;
    color: var(--mkt-color-text-muted);
  }

  .tier-description {
    font-size: 0.875rem;
    color: var(--mkt-color-text-muted);
    margin: 0;
  }

  /* Feature List */
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--mkt-color-text-dark);
  }

  .check-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--mkt-color-primary);
    flex-shrink: 0;
  }

  .tier-cta {
    margin-top: auto;
  }

  /* Trust Section */
  .trust-section {
    padding: 3rem 0;
    background: var(--mkt-color-background-tinted);
  }

  .trust-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--mkt-color-text-muted);
  }

  .trust-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--mkt-color-primary);
  }

  /* FAQ Section */
  .faq-section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--mkt-color-text-dark);
    text-align: center;
    margin: 0 0 3rem;
  }

  .faq-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .faq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .faq-item {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-marketing-card-small);
  }

  .faq-question {
    font-size: 1rem;
    font-weight: 600;
    color: var(--mkt-color-text-dark);
    margin: 0 0 0.75rem;
  }

  .faq-answer {
    font-size: 0.875rem;
    color: var(--mkt-color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA Section */
  .cta-section {
    padding: 4rem 0;
    text-align: center;
    background: linear-gradient(135deg, 
      var(--mkt-color-primary) 0%, 
      #5f2db0 100%);
  }

  .cta-title {
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.75rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 2rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Button overrides for CTA section */
  .cta-section :global(.btn-primary) {
    background: white;
    color: var(--mkt-color-primary);
  }

  .cta-section :global(.btn-primary:hover) {
    background: rgba(255, 255, 255, 0.9);
  }

  .cta-section :global(.btn-outline) {
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
  }

  .cta-section :global(.btn-outline:hover) {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }
</style>
